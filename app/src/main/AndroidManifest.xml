<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
<!--    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />-->

    <application
        android:name=".TNApplication"
        android:allowBackup="false"
        android:largeHeap="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.SagaChat">
        <activity
            android:name=".activity.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.SagaChat">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>


        <activity
            android:name=".activity.TempActivity"
            android:exported="true"
            android:theme="@style/Theme.SagaChat">
        </activity>

        <activity
            android:name=".activity.ColorShowcaseActivity"
            android:exported="false"
            android:theme="@style/Theme.SagaChat">
        </activity>

        <activity
            android:name=".ui.screens.crash_report.CrashReportActivity"
            android:exported="false"
            android:label="Crash report"
            android:theme="@style/Theme.SagaChat">
        </activity>

        <service
            android:name="com.moorixlabs.download_manager.HxdService"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="true" />

        <service
            android:name=".service.inference.InferenceService"
            android:process=":inference"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="true" />

        <service
            android:name=".service.server.RemoteServerService"
            android:process=":server"
            android:exported="false"
            android:foregroundServiceType="dataSync"
            android:stopWithTask="false" />

<!--        <service-->
