{
  "example one": {
    "title": "Check For Updates at 12:00",
    "description": "This work-flow Checking For Update of apps from playstore at 12:00 24x7 & Updating them",
    "tools_called": [
      "AppIO",
      "UiNav"
    ],
    "steps": [
      {
        "tool": "AppIO",
        "action": "check",
        "data": "PlayStore"
      },
      {
        "tool": "AppIO",
        "action": "open",
        "data": "PlayStore"
      },
      {
        "tool": "AppIO",
        "action": "open",
        "data": "PlayStore"
      }
    ]
  },
  "example 2": {
    "title": "Scrolling PlayStore",
    "description": "A Simple Scroll Ui Automation",
    "tools_called": [
      "AppIO",
      "UiNav"
    ],
    "steps": [
      {
        "tool": "AppIO",
        "args": {
          "action": "open",
          "packageName": "PlayStore"
        }
      },
      {
        "tool": "UiNav",
        "args": {
          "action": "scrollDown",
          "times": "4"
        }
      },
      {
        "tool": "AppIO",
        "args": {
          "action": "close",
          "packageName": "PlayStore"
        }
      }
    ]
  }
}